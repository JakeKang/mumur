# Database path for better-sqlite3 (absolute path recommended in production)
NEXT_DB_PATH=./data/mumur.db

# PostgreSQL connection string (when set, migration path uses postgres tooling)
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/mumur
# PGSSL=disable
# PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECT_TIMEOUT_MS=10000

# Public app URL used by E2E/integration scripts and external links
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3001

# Reserved for upcoming auth hardening (currently not consumed in runtime code)
# SESSION_SECRET=replace-with-32+char-random-string
